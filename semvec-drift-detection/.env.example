# Copy this file to .env and fill in your local values.
#
#   cp .env.example .env
#
# .env is gitignored — secrets stay local.
# Every variable below is required (the demo and tests refuse to start if
# any are unset, instead of silently falling back to baked-in defaults).

# ── Neo4j ─────────────────────────────────────────────────────────────
NEO4J_TEST_URI=bolt://localhost:7687
NEO4J_TEST_USER=neo4j
NEO4J_TEST_PASSWORD=
NEO4J_TEST_DATABASE=neo4j

# ── LLM (only consulted when interactive_demo.py runs with LLM enabled) ─
# Any OpenAI-compatible endpoint works (vLLM, Ollama, OpenAI itself, …).
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
# Set to 1 to allow reasoning models (Qwen3, DeepSeek-R1, o1-style) to
# emit chain-of-thought; default 0 forces direct answers.
OPENAI_ENABLE_THINKING=0

# ── Demo drift-detection thresholds ───────────────────────────────────
# A DRIFT is flagged when drift_score >= DRIFT_THRESHOLD AND the cosine
# similarity to the accumulated context is <= DRIFT_SIM_CEILING. Lower
# the threshold to be more sensitive, raise it to be stricter.
DRIFT_THRESHOLD=0.35
DRIFT_SIM_CEILING=0.45

# ── Healthcare fixtures (optional override) ───────────────────────────
# By default the seed script reads the fixtures bundled in this repo at
# healthcare-fixtures/. Override these to point at a freshly generated
# scaffold (e.g. uvx create-context-graph ...).
# FIXTURES_PATH=/tmp/healthcare-test-data/data/fixtures.json
# HEALTHCARE_SCHEMA_PATH=/tmp/healthcare-test-data/cypher/schema.cypher
